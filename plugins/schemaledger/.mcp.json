{
  "mcpServers": {
    "schemaledger": {
      "type": "stdio",
      "command": "uv",
      "args": [
        "run",
        "--project",
        "../..",
        "python",
        "-m",
        "schemaledger.mcp",
        "--workspace",
        "../../workspace",
        "--dsn",
        "postgresql://postgres:postgres@127.0.0.1:55432/schemaledger_fresh"
      ],
      "env": {
        "PYTHONNOUSERSITE": "1",
        "PYTHONPATH": "../../src:../..",
        "SCHEMALEDGER_LLM_PROVIDER": "lmstudio",
        "SCHEMALEDGER_EMBEDDING_PROVIDER": "lmstudio",
        "SCHEMALEDGER_LM_STUDIO_BASE_URL": "http://127.0.0.1:1234",
        "SCHEMALEDGER_LM_STUDIO_MODEL": "qwen3.5-35b-a3b-uncensored-claude-opus-4.6-affine",
        "SCHEMALEDGER_LM_STUDIO_EMBEDDING_MODEL": "text-embedding-nomic-embed-text-v1.5",
        "SCHEMALEDGER_OLLAMA_BASE_URL": "http://127.0.0.1:11434",
        "SCHEMALEDGER_OLLAMA_MODEL": "",
        "SCHEMALEDGER_OLLAMA_EMBEDDING_MODEL": "",
        "SCHEMALEDGER_OPENAI_BASE_URL": "https://api.openai.com",
        "SCHEMALEDGER_OPENAI_API_KEY": "",
        "SCHEMALEDGER_OPENAI_MODEL": "",
        "SCHEMALEDGER_OPENAI_EMBEDDING_MODEL": "",
        "SCHEMALEDGER_GEMINI_BASE_URL": "https://generativelanguage.googleapis.com",
        "SCHEMALEDGER_GEMINI_API_KEY": "",
        "SCHEMALEDGER_GEMINI_MODEL": "",
        "SCHEMALEDGER_GEMINI_EMBEDDING_MODEL": "",
        "SCHEMALEDGER_POSTGRES_DSN": "postgresql://postgres:postgres@127.0.0.1:55432/schemaledger_fresh"
      },
      "note": "Repo-local SchemaLedger MCP server. LLM and embedding providers can switch between LM Studio, Ollama, OpenAI, and Gemini through env vars."
    }
  }
}
