# SchemaLedger runtime selection
SCHEMALEDGER_LLM_PROVIDER=lmstudio
SCHEMALEDGER_EMBEDDING_PROVIDER=

# LM Studio
SCHEMALEDGER_LM_STUDIO_BASE_URL=http://127.0.0.1:1234
SCHEMALEDGER_LM_STUDIO_MODEL=qwen3.5-35b-a3b-uncensored-claude-opus-4.6-affine
SCHEMALEDGER_LM_STUDIO_EMBEDDING_MODEL=text-embedding-nomic-embed-text-v1.5
SCHEMALEDGER_LM_STUDIO_TIMEOUT=30

# Ollama
SCHEMALEDGER_OLLAMA_BASE_URL=http://127.0.0.1:11434
SCHEMALEDGER_OLLAMA_MODEL=
SCHEMALEDGER_OLLAMA_EMBEDDING_MODEL=
SCHEMALEDGER_OLLAMA_TIMEOUT=30

# OpenAI embeddings only
SCHEMALEDGER_OPENAI_BASE_URL=https://api.openai.com
SCHEMALEDGER_OPENAI_API_KEY=
SCHEMALEDGER_OPENAI_EMBEDDING_MODEL=text-embedding-3-small
SCHEMALEDGER_OPENAI_TIMEOUT=30

# Gemini embeddings only
SCHEMALEDGER_GEMINI_BASE_URL=https://generativelanguage.googleapis.com
SCHEMALEDGER_GEMINI_API_KEY=
SCHEMALEDGER_GEMINI_EMBEDDING_MODEL=gemini-embedding-001
SCHEMALEDGER_GEMINI_TIMEOUT=30

# Optional local overrides
SCHEMALEDGER_POSTGRES_DSN=
SCHEMALEDGER_CLAUDE_MCP_URL=http://127.0.0.1:5064/sse
