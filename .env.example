# Copy this file to `.env` before starting TraceRelay.
# Codex and Claude Code plugin installs should be rerun after changing this file:
#   bash ./scripts/install_codex_plugin.sh
#   bash ./scripts/install_claude_code_plugin.sh

# TraceRelay runtime selection
TRACERELAY_LLM_PROVIDER=lmstudio
TRACERELAY_EMBEDDING_PROVIDER=

# LM Studio
TRACERELAY_LM_STUDIO_BASE_URL=http://127.0.0.1:1234
TRACERELAY_LM_STUDIO_MODEL=qwen3.5-35b-a3b-uncensored-claude-opus-4.6-affine
TRACERELAY_LM_STUDIO_EMBEDDING_MODEL=text-embedding-nomic-embed-text-v1.5
TRACERELAY_LM_STUDIO_TIMEOUT=600

# Ollama
TRACERELAY_OLLAMA_BASE_URL=http://127.0.0.1:11434
TRACERELAY_OLLAMA_MODEL=
TRACERELAY_OLLAMA_EMBEDDING_MODEL=
TRACERELAY_OLLAMA_TIMEOUT=600

# OpenAI structured extraction + embeddings
TRACERELAY_OPENAI_BASE_URL=https://api.openai.com
TRACERELAY_OPENAI_API_KEY=
TRACERELAY_OPENAI_MODEL=
TRACERELAY_OPENAI_EMBEDDING_MODEL=text-embedding-3-small
TRACERELAY_OPENAI_TIMEOUT=600

# Gemini structured extraction + embeddings
TRACERELAY_GEMINI_BASE_URL=https://generativelanguage.googleapis.com
TRACERELAY_GEMINI_API_KEY=
TRACERELAY_GEMINI_MODEL=
TRACERELAY_GEMINI_EMBEDDING_MODEL=gemini-embedding-001
TRACERELAY_GEMINI_TIMEOUT=600

# Optional local overrides
TRACERELAY_POSTGRES_DSN=
TRACERELAY_PLUGIN_MCP_URL=http://127.0.0.1:5064/mcp
